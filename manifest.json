{
  "manifest_version": 3,
  "name": "I.C.E. Scripture Engine",
  "version": "1.0.0",
  "description": "Sacred reference formatter for scripture and related reading.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "engine.js",
        "content.js",
        "pageOverlay.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "lexicon.json",
        "Rules.json",
        "phrases.json",
        "DIVINE_TITLES.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
